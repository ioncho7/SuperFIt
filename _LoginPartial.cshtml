@using Microsoft.AspNetCore.Identity
@using SuperFit.Models
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager

@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    var name = user?.DisplayName ?? User.Identity!.Name;

    <span class="navbar-text me-2">
        Здравей, @name
    </span>

    <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
        <button type="submit" class="btn btn-link nav-link">Изход</button>
    </form>
}
else
{
    <a class="btn btn-outline-primary" asp-area="Identity" asp-page="/Account/Login">
        Вход
    </a>

    <a class="btn btn-primary ms-2" asp-area="Identity" asp-page="/Account/Register">
        Регистрация
    </a>

}
