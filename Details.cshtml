@model SuperFit.Models.ContactMessage

@{
    ViewData["Title"] = "Детайли за съобщение";
}

<h1>Детайли за съобщение</h1>
@if (Model.IsOrderNotification && Model.OrderId != null && User.IsInRole("Admin"))
{
    <form asp-controller="Orders" asp-action="ApproveFromMessage" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="orderId" value="@Model.OrderId" />
        <input type="hidden" name="messageId" value="@Model.Id" />
        <button type="submit" class="btn btn-success">
            Одобри поръчката
        </button>
    </form>
}

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Име</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Имейл</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Тема</dt>
            <dd class="col-sm-9">@Model.Subject</dd>

            <dt class="col-sm-3">Дата</dt>
            <dd class="col-sm-9">@Model.SentOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>

            <dt class="col-sm-3">Съобщение</dt>
            <dd class="col-sm-9">@Model.Message</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</div>
