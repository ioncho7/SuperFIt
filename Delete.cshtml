@model SuperFit.Models.ContactMessage

@{
    ViewData["Title"] = "Изтриване на съобщение";
}

<h1>Изтриване на съобщение</h1>

<div class="alert alert-warning">
    Сигурни ли сте, че искате да изтриете това съобщение?
</div>

<div class="card">
    <div class="card-body">
        <h5 class="mb-3">@Model.Subject</h5>
        @if (Model.IsOrderNotification)
        {
            <span class="badge bg-primary mb-3">Поръчка</span>
        }


        <p class="mb-1"><b>От:</b> @Model.Name (@Model.Email)</p>
        <p class="text-muted"><b>Дата:</b> @Model.SentOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>

        <p class="mt-3">@Model.Message</p>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-danger">Изтрий</button>
            <a asp-action="Index" class="btn btn-secondary">Отказ</a>
        </form>
    </div>
</div>
