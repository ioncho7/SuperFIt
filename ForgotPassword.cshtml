@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Забравена парола";
}

<h1>@ViewData["Title"]</h1>
<p>Въведете имейла на акаунта. Ще “изпратим” линк за смяна на паролата.</p>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-floating mb-3">
        <input asp-for="Input.Email" class="form-control" autocomplete="email" />
        <label asp-for="Input.Email">Имейл</label>
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Изпрати линк</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
